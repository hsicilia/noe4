{% extends 'base.html.twig' %}

{% set menu='usuario' %}

{% block title %}{{ 'title.especie.buscar' | trans }}{% endblock %}

{% block titular %}{{ 'title.especie.buscar' | trans }}{% endblock %}

{% block contenido %}

{% for flashMessage in app.flashes('notice') %}
    <div class="flash-notice">
        {{ flashMessage | trans }}
    </div>
{% endfor %}

<fieldset>
    {{ form_start(formulario) }}

        {{ form_errors(formulario) }}

        {{ form_row(formulario.nombre) }}
        {{ form_row(formulario.comun) }}
        <div class="separador">
            {{ form_row(formulario.invasora) }}
            {{ form_row(formulario.peligroso) }}
            {{ form_row(formulario.cites) }}
        </div>
        {{ form_row(formulario.enviar) }}
        {% if formulario.informePDF is defined %}
            <span class="buttons" style="margin-left: 220px;">
                {{ form_widget(formulario.informePDF) }}
                {{ form_widget(formulario.informeCSV) }}
                {{ form_widget(formulario.informeEXCEL) }}
            </span>
        {% endif %}
        {{ form_rest(formulario) }}
    {{ form_end(formulario) }}
</fieldset>
{% endblock %}